    "test:component": "cypress run --component",
    "test:e2e": "cypress run --e2e",
    "test:e2e:coverage": "INSTRUMENT_CODE=true cypress run --e2e",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
