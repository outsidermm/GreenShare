    "test:unit:coverage": "vitest run --coverage",
    "test:coverage": "npm run test:e2e:coverage && npm run test:unit:coverage",
    "coverage:report": "nyc report",
    "coverage:open": "open coverage/index.html"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "axios": "^1.7.9",
    "framer-motion": "^12.23.0",
    "next": "15.3.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "react-responsive-carousel": "^3.2.23",
    "react-select": "^5.10.1",
    "sweetalert": "^2.1.2",
    "swiper": "^11.2.8"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.14.5",
    "@eslint/eslintrc": "^3",
